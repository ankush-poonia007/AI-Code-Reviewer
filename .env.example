# ==========================
# Application
# ==========================
APP_NAME="AI Code Review Assistant"
APP_VERSION="1.0.0"
DEBUG=True
HOST="127.0.0.1"
PORT=8000

# ==========================
# Database
# ==========================
DATABASE_URL="sqlite:///./ai_code_reviewer.db"

# ==========================
# AI Provider
# ==========================
LLM_PROVIDER=groq
LLM_REQUEST_TIMEOUT_SECONDS=120
MAX_TOKENS=4096
TEMPERATURE=0.2

# ==========================
# Groq
# ==========================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ==========================
# Gemini
# ==========================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ==========================
# Uploads
# ==========================
UPLOAD_DIR=uploads
REPORT_DIR=reports
MAX_FILE_SIZE_MB=5