# =====================================================================
# AI Code Reviewer — Environment Configuration Template
# Copy this file to .env and fill in your values.
# =====================================================================

# Core Application
APP_NAME=AI Code Review Assistant
APP_VERSION=1.0.0
DEBUG=False
HOST=127.0.0.1
PORT=8000

# Database
DATABASE_URL=sqlite:///./ai_code_reviewer.db

# LLM Provider (supported: groq, gemini)
LLM_PROVIDER=groq
MAX_TOKENS=4096
TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT_SECONDS=120

# Groq Provider
GROQ_API_KEY=""
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini Provider
GEMINI_API_KEY=""
GEMINI_MODEL=gemini-2.5-flash

# File Upload Limits
UPLOAD_DIR=uploads
REPORT_DIR=reports
MAX_FILE_SIZE_MB=5
